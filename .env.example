# Port the web UI listens on (also published on the host).
B81_PORT=8000
# Set to 1 when serving over HTTPS so the auth cookie gets the Secure flag.
B81_COOKIE_SECURE=0
# Fernet key used to encrypt the "Stay logged in" cookie. Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# If unset, a fresh key is generated each boot — remember-me cookies won't survive a restart.
B81_COOKIE_KEY=
# How many seconds before class start to begin fast polling.
# 1800 = 30 min, 3600 = 1 h, 7200 = 2 h.
B81_TIME_BEFORE_EVENT=1800
B81_POLL_MIN_SECS=2
B81_POLL_MAX_SECS=5
B81_POLL_SLOW_MIN_SECS=5
B81_POLL_SLOW_MAX_SECS=15
B81_DEFAULT_CITY=BER
# Optional ntfy.sh topic for phone push notifications.
B81_NTFY_TOPIC=

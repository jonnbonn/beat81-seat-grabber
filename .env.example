B81_EMAIL=jonas@example.com
B81_PASSWORD=replace-me
# Port the web UI listens on (also published on the host).
B81_PORT=8000
# How many seconds before class start to begin fast polling.
# 1800 = 30 min, 3600 = 1 h, 7200 = 2 h.
B81_TIME_BEFORE_EVENT=1800
B81_POLL_MIN_SECS=2
B81_POLL_MAX_SECS=5
B81_DEFAULT_CITY=BER
# Optional ntfy.sh topic for phone push notifications.
B81_NTFY_TOPIC=
